#!/bin/bash
# Standalone bibliometrics Binder postBuild (repo root = bibliometrics/).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

mkdir -p output/review_metrics output/figures .matplotlib

if [[ ! -f config.yaml ]]; then
  cp config.yaml.example config.yaml
fi

shopt -s nullglob
csv_files=(checkpoints/*.csv)
shopt -u nullglob

if [[ ${#csv_files[@]} -eq 0 ]]; then
  echo "error: no CSV files in $ROOT/checkpoints" >&2
  exit 1
fi

for f in "${csv_files[@]}"; do
  cp "$f" output/
done

printf '%s\n' "openalex_id,doi,status,mention_count,matched_terms,match_strength,error" \
  > output/clamps_local_scan_log.csv

echo "Binder postBuild complete: ${#csv_files[@]} checkpoints -> output/"
