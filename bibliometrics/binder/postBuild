#!/bin/bash
set -euo pipefail
# Binder postBuild: prepare workspace for quick reproduction notebook.

mkdir -p output/review_metrics output/figures .matplotlib

if [[ ! -f config.yaml ]]; then
  cp config.yaml.example config.yaml
fi

for f in checkpoints/*.csv; do
  cp "$f" output/
done

if [[ ! -s output/clamps_local_scan_log.csv ]]; then
  echo "openalex_id,doi,status,mention_count,matched_terms,match_strength,error" > output/clamps_local_scan_log.csv
fi

echo "Binder postBuild complete: checkpoints restored to output/"
